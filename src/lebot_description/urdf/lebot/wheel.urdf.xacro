<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:include filename="$(find lebot_description)/urdf/lebot/common_inertia.xacro" />
    <xacro:macro name="wheel_xacro" params="wheel_name xyz length radius link_prefix:=''">
        <link name="${link_prefix}${wheel_name}_wheel_link">
            <visual>
                <origin xyz="0 0 0" rpy="1.57079 0 0" />
                <geometry>
                    <cylinder length="${length}" radius="${radius}" />
                </geometry>
                <material name="black">
                    <color rgba="0.0 0.0 0.0 0.8"/>
                </material>
            </visual>
            <collision>
                <origin xyz="0 0 0" rpy="1.57079 0 0" />
                <geometry>
                    <cylinder length="${length}" radius="${radius}" />
                </geometry>
            </collision>
            <xacro:cylinder_inertia m="0.3" r="${radius}" h="${length}"/>
        </link>
        <gazebo reference="${link_prefix}${wheel_name}_wheel_link">
            <material>Gazebo/Black</material>
            <mu1>1.0</mu1>
            <mu2>0.18</mu2>
            <kp>1000000.0</kp>
            <kd>100.0</kd>
            <fdir1>1 0 0</fdir1>
            <maxVel>10.0</maxVel>
            <minDepth>0.001</minDepth> 
        </gazebo>


        <joint name="${wheel_name}_wheel_joint" type="continuous">
            <parent link="${link_prefix}base_link" />
            <child link="${link_prefix}${wheel_name}_wheel_link" />
            <origin xyz="${xyz}" />
            <axis xyz="0 1 0" />
            <dynamics damping="0.005" friction="0.0" />
        </joint>
    </xacro:macro>
</robot>
